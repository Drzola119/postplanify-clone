# Firebase Web App Config (client-side, public)
# Get from: Firebase Console → Project Settings → General → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef

# Firebase Admin SDK (server-side, SECRET — do not commit)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Or set FIREBASE_PRIVATE_KEY inline with \n escaped as \\n
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Bunny.net Storage (image/video uploads)
# Get from: bunny.net → Storage → your zone → FTP & API Access
# Storage API: PUT to https://{HOSTNAME}/{ZONE}/{path} with AccessKey header
# CDN delivers from: https://{CDN_HOSTNAME}/{path}
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_STORAGE_PASSWORD=your-storage-zone-password
BUNNY_CDN_HOSTNAME=https://your-pull-zone.b-cdn.net

# n8n webhook URL for the AutoPost workflow (proxied via VPS nginx)
# Receives the per-platform publish payload and calls upload-post.com.
N8N_WEBHOOK_URL=https://your-domain.example/webhook/autopost

# Default upload-post.com username (used as fallback when no brand/account is selected)
UPLOAD_POST_DEFAULT_USERNAME=your-upload-post-username

# upload-post.com API key (server-side, SECRET — do not commit)
# JWT token from https://app.upload-post.com → API Keys
# Used by /api/social-accounts to fetch connected accounts.
UPLOAD_POST_API_KEY=your-upload-post-jwt-token-here

# Groq API key (server-side, SECRET — do not commit)
# Used by /api/ai/caption for AI caption generation:
#   - llama-3.2-90b-vision-preview for image analysis
#   - llama-3.1-70b-versatile for video-title caption generation
# Get from: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here

# ─────────────────────────────────────────────────────────────────────────────
# AI Outpainting Engine (adsify poster web app — separate Express service)
# ─────────────────────────────────────────────────────────────────────────────
# The composer calls this engine to generate per-ratio image variants
# (4:5 / 1:1 / 16:9 / 2:3) before publishing. trustiify.agency trusts the
# engine for generation only — it then publishes each variant per-platform
# to upload-post.com using the workspace's own API key.
#
# ADSIFY_ENGINE_URL — Base URL of the engine. Local: http://127.0.0.1:3000
#                     VPS:   https://engine.trustiify.agency
# ADSIFY_ENGINE_API_KEY — Optional HMAC shared secret. When set, the engine
#                         rejects requests that don't include it as
#                         `X-Engine-Api-Key`. Leave blank in dev.
# Get the URL/key from the VPS ops doc; ask the user for the production
# value via hPanel env (paste into the same row as the other *_API_KEYs).
ADSIFY_ENGINE_URL=http://127.0.0.1:3000
# ADSIFY_ENGINE_API_KEY=

# Vercel Analytics Integration (Phase C)
# VERCEL_ACCESS_TOKEN=your-vercel-access-token-here
# VERCEL_PROJECT_ID=your-vercel-project-id-here
