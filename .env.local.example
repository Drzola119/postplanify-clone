# Firebase Web App Config (client-side, public)
# Get from: Firebase Console → Project Settings → General → Your apps → Web app → Config
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef

# Firebase Admin SDK (server-side, SECRET — do not commit)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Or set FIREBASE_PRIVATE_KEY inline with \n escaped as \\n
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# Bunny.net Storage (image/video uploads)
# Get from: bunny.net → Storage → your zone → FTP & API Access
# Storage API: PUT to https://{HOSTNAME}/{ZONE}/{path} with AccessKey header
# CDN delivers from: https://{CDN_HOSTNAME}/{path}
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_STORAGE_PASSWORD=your-storage-zone-password
BUNNY_CDN_HOSTNAME=https://your-pull-zone.b-cdn.net

# n8n webhook URL for the AutoPost workflow (proxied via VPS nginx)
# Receives the per-platform publish payload and calls upload-post.com.
N8N_WEBHOOK_URL=https://your-domain.example/webhook/autopost

# Default upload-post.com username (used as fallback when no brand/account is selected)
UPLOAD_POST_DEFAULT_USERNAME=your-upload-post-username

# upload-post.com API key (server-side, SECRET — do not commit)
# JWT token from https://app.upload-post.com → API Keys
# Used by /api/social-accounts to fetch connected accounts.
UPLOAD_POST_API_KEY=your-upload-post-jwt-token-here
